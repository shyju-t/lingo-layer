{
  "manifest_version": 3,
  "name": "LingoLayer",
  "version": "1.0.0",
  "description": "Context-aware German immersion. Learn while you doomscroll.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.featherless.ai/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.elevenlabs.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://reddit.com/*",
    "https://*.reddit.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.reddit.com/*", "*://reddit.com/*"],
      "js": [
        "lib/selectors.js",
        "lib/prompt.js",
        "lib/llm-client.js",
        "lib/tts.js",
        "content/injector.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
